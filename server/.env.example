# ============================================================================
# Worktide server configuration (example)
#   Copy to `.env` and fill in. Never commit the real `.env`.
#   All keys are optional unless noted; defaults live in app/config.py.
# ============================================================================

# --- Database --------------------------------------------------------------
# SQLite by default; switch to postgresql+psycopg://user:pass@host/db for scale.
DATABASE_URL=sqlite:///./data/employees.db

# --- Admin / API auth (REQUIRED in production) -----------------------------
# Without these the admin/API surface refuses all access.
#   ADMIN_PASSWORD_HASH : PBKDF2-SHA256 hash. Generate with the helper:
#       python -c "from app.auth import hash_password; print(hash_password('your-password'))"
#   ADMIN_SESSION_SECRET: random 32+ bytes for HMAC token signing:
#       python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# --- API docs --------------------------------------------------------------
# Keep false in production to hide /docs, /redoc and /openapi.json.
DOCS_ENABLED=false

# --- CORS ------------------------------------------------------------------
# JSON array of allowed admin origins.
CORS_ORIGINS=["http://localhost:5173"]

# --- Detection thresholds --------------------------------------------------
IDLE_THRESHOLD_SECONDS=900
OFFLINE_THRESHOLD_SECONDS=90
REPORT_INTERVAL_SECONDS=30

# --- Telegram bot ----------------------------------------------------------
# Set TELEGRAM_ENABLED=true and provide a token to enable the bot / notifications.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_COOLDOWN_SECONDS=1800
TELEGRAM_TIMEOUT_SECONDS=10
# Comma-separated Telegram user_ids that get @mentioned on idle events.
ADMIN_TELEGRAM_USER_IDS=

# --- Auto-update (agent) ---------------------------------------------------
# Must match the agent's hmac_secret. Change in production.
UPDATE_HMAC_SECRET=change-me-in-production
UPDATE_RELEASE_DIR=./data/releases

# --- Retention / cleanup ---------------------------------------------------
LOG_RETENTION_DAYS=40
CLEANUP_INTERVAL_SECONDS=86400
CLEANUP_BATCH_SIZE=5000
WINDOW_RAW_RETENTION_DAYS=7
WINDOW_SESSIONS_RETENTION_DAYS=40
MAX_QUERY_LIMIT=500

# --- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=server.log
LOG_FILE_MAX_BYTES=10485760
LOG_BACKUP_COUNT=7
